# ==========================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All configuration is via env vars; no secrets are hardcoded in the code.
# ==========================================================================

# ---- Vector store ----
CHROMA_PERSIST_DIR=./chroma_db          # where ChromaDB persists to disk
CHROMA_COLLECTION=rag_chunks            # collection name

# ---- Chunking ----
CHUNK_SIZE_TOKENS=500                   # tokens per chunk (default 500)
CHUNK_OVERLAP_TOKENS=50                 # overlap between chunks (default 50)

# ---- Embeddings ----
# EMBEDDING_PROVIDER options:
#   openai                -> text-embedding-3-small, 1536-dim (needs OPENAI_API_KEY)
#   sentence-transformers -> local CPU model, free, no key (pip install sentence-transformers)
#   local                 -> deterministic hash embedding, offline, zero deps, LOW quality
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=text-embedding-3-small                 # used when provider=openai
ST_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2  # used when provider=sentence-transformers (384-dim)
EMBEDDING_DIM=1536                                     # used only by the "local" hash provider

# ---- Generation (LLM) ----
# LLM_PROVIDER options: "groq" | "openai" | "anthropic".
# Groq is OpenAI-compatible (chat only; it has NO embeddings endpoint).
LLM_PROVIDER=groq
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_LLM_MODEL=gpt-4o-mini
ANTHROPIC_LLM_MODEL=claude-haiku-4-5

# ---- Retrieval ----
TOP_K=5                                 # default number of chunks to retrieve
# Minimum cosine similarity a chunk must clear to be considered "relevant".
# If no chunk clears this, the API returns "no relevant context found" instead
# of hallucinating. Tune per corpus/embedding model.
SIMILARITY_THRESHOLD=0.25

# ---- Secrets (leave blank in this example file) ----
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Logging ----
QUERY_LOG_PATH=./logs/queries.log
