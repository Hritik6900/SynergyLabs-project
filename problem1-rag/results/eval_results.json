      "question": "How does Vote Rakshak's smart contract prevent double voting?",
      "gold_chunk_ids": [
        "ffc6feae99088350a9fe590f1b722ed434de7c1531cdd91227e681d34439931c"
      ],
      "retrieved_chunk_ids": [
