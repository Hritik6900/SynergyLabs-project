# ---- Groq API (OpenAI-compatible endpoint) ----
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Judge and generator are configured INDEPENDENTLY and must be
# meaningfully-different model FAMILIES (self-enhancement bias mitigation).
#
# Defaults (as of 2026-07, llama-3.3-70b-versatile was deprecated 2026-06-17):
#   Judge     = GPT-OSS family  (OpenAI open-weight MoE, strong reasoner, JSON mode)
#   Generator = Qwen  family    (Alibaba — different pretraining corpus / tokenizer / RLHF)
#
# Swap either freely without touching code. To flip roles just swap the two values.
GROQ_JUDGE_MODEL=openai/gpt-oss-120b
GROQ_GENERATOR_MODEL=qwen/qwen3.6-27b

# Optional overrides
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_JUDGE_TEMPERATURE=0.0
# Temperature used for test-retest consistency runs (must be > 0 to see flips)
GROQ_RETEST_TEMPERATURE=0.7
GROQ_MAX_RETRIES=6

# ---- Performance / free-tier knobs ----
# GPT-OSS models "reason" before answering; "low" cuts reasoning tokens => much
# faster & cheaper, plenty for rubric scoring. (medium|high also valid.)
GROQ_JUDGE_REASONING_EFFORT=low
# Steady seconds between calls to stay UNDER a free-tier per-minute token limit
# (bursting then eating a 30s backoff is slower). 0 = off. Set ~3 on free tier.
GROQ_MIN_CALL_INTERVAL=0
# Tip: the sample results/ in this repo were generated with judge=openai/gpt-oss-20b
# (same GPT-OSS family, faster) to stay under free-tier limits. gpt-oss-120b is the
# stronger default judge; either works — self-enhancement holds vs the qwen generator.
